# MongoDB Connection
MONGODB_URI=mongodb://localhost:27017/uniconvert

# Server Configuration
PORT=5000
NODE_ENV=development

# File Upload Configuration
MAX_FILE_SIZE=10485760
UPLOAD_DIR=./uploads
